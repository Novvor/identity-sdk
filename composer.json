{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "novvor/identity-sdk",
  "version": "1.0.0",
  "description": "Novvor Identity SDK (JWT verification, JWKS client, SSO exchange client, session mapping).",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "firebase/php-jwt": "^7.0",
    "guzzlehttp/guzzle": "^7.0",
    "psr/simple-cache": "^3.0"
  },
  "suggest": {
    "illuminate/support": "Required only when using the Laravel ServiceProvider adapter."
  },
  "autoload": {
    "psr-4": {
      "Novvor\\Identity\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Novvor\\Identity\\IdentityServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
